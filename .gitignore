# synthforge - Development Environment
# This .gitignore is for the synthforge workspace itself
# Individual projects should have their own .gitignore

# ============================================================================
# Projects Directory - Each project is its own repo
# ============================================================================
projects/
!projects/.gitkeep

# ============================================================================
# Internal/Personal Notes - Keep local only
# ============================================================================
.internal/

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# Virtual Environments
# ============================================================================
.venv/
venv/
ENV/
env/
.virtualenv/

# ============================================================================
# IDE / Editors
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# AI Tools
# ============================================================================
.cursor/
.continue/
.aider/
.copilot/

# ============================================================================
# Sensitive Files
# ============================================================================
.env
.env.local
.env.*.local
*.key
*.pem
secrets.yaml
secrets.json
config.local.yaml

# ============================================================================
# Logs
# ============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# OS
# ============================================================================
Thumbs.db
.DS_Store
desktop.ini

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
*.bak
*.swp
*~

# ============================================================================
# Test Coverage
# ============================================================================
.coverage
htmlcov/
.pytest_cache/
.tox/

# ============================================================================
# Personal Notes (keep in local only)
# ============================================================================
scratch/
notes/
TODO_PERSONAL.md
BRAINSTORM.md

# ============================================================================
# Build Artifacts
# ============================================================================
*.pyc
*.pyo
*.exe
*.dll
*.so
*.dylib

# ============================================================================
# Keep These Files
# ============================================================================
!.gitkeep
!.gitignore
